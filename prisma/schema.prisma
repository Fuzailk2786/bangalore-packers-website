datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum MoveType {
  DOMESTIC_HOUSE
  INTERNATIONAL_HOUSE
  OFFICE_RELOCATION
  VEHICLE_TRANSPORT
  PACKING_ONLY
}

enum LeadStatus {
  NEW
  CONTACTED
  SURVEY_SCHEDULED
  QUOTED
  BOOKED
  COMPLETED
  CANCELLED
}

model Lead {
  id               String       @id @default(uuid())
  fullName         String
  email            String
  phone            String
  originCity       String
  destinationCity String
  moveDate         DateTime
  moveType         MoveType
  cargoDescription String?
  volumeEstimate   String?      // Cubic feet or truck load estimate
  isVehicleIncluded Boolean     @default(false)
  status           LeadStatus   @default(NEW)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  notes            String?

  @@index([email])
  @@index([phone])
  @@index([status])
}

model CallbackRequest {
  id          String   @id @default(uuid())
  fullName    String
  phone       String
  isCalled    Boolean  @default(false)
  requestedAt DateTime @default(now())
  calledAt    DateTime?

  @@index([phone])
  @@index([isCalled])
}
